<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sample Details</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>Sample Details</h1>
    <p><a href="/dashboard">Back to Dashboard</a></p>

    <div class="section-title">Sample Information</div>
    <div class="grid">
      <div>
        <label>Lab ID</label>
        <input value="<%= sample.labId %>" readonly />
      </div>

      <div>
        <label>Vessel</label>
        <input value="<%= sample.vessel %>" readonly />
      </div>

      <div>
        <label>Operation Stage</label>
        <input value="<%= sample.operationStage %>" readonly />
      </div>

      <div>
        <label>Client</label>
        <input value="<%= sample.client %>" readonly />
      </div>

      <div>
        <label>Cargo</label>
        <input value="<%= sample.cargo %>" readonly />
      </div>

      <div>
        <label>Tank / Source</label>
        <input value="<%= sample.source %>" readonly />
      </div>

      <div>
        <label>Status</label>
        <input value="<%= sample.status %>" readonly />
      </div>

      <div>
        <label>Rack</label>
        <input value="<%= sample.rack %>" readonly />
      </div>

      <div>
        <label>Shelf</label>
        <input value="<%= sample.shelf %>" readonly />
      </div>

      <div>
        <label>Position</label>
        <input value="<%= sample.position %>" readonly />
      </div>

      <div>
        <label>Current Quantity</label>
        <input value="<%= sample.currentQuantity ?? '' %>" readonly />
      </div>

      <div>
        <label>Quantity Unit</label>
        <input value="<%= sample.quantityUnit || '' %>" readonly />
      </div>

      <div>
        <label>Current Location</label>
        <input value="<%= sample.currentLocation || '' %>" readonly />
      </div>

      <div>
        <label>Movement Count</label>
        <input value="<%= sample.movementCount ?? 0 %>" readonly />
      </div>
    </div>

    <div class="section-title">Log Movement</div>
    <div class="grid">
      <div>
        <label for="movementType">Movement Type</label>
        <select id="movementType">
          <option value="TRANSFERRED_TO_LAGOS">Transferred to Lagos</option>
          <option value="TRANSFERRED_TO_LOME">Transferred to Lomé</option>
          <option value="RETRIEVED_FOR_TEST">Retrieved for Test</option>
          <option value="RETURNED_TO_STORE">Returned to Store</option>
          <option value="CONSUMED_IN_TEST">Consumed in Test</option>
          <option value="DISPOSED">Disposed</option>
        </select>
      </div>

      <div>
        <label for="fromLocation">From Location</label>
        <input
          type="text"
          id="fromLocation"
          placeholder="e.g. Lomé Store, Lagos Lab"
          value="<%= sample.currentLocation || '' %>"
        />
      </div>

      <div>
        <label for="toLocation">To Location</label>
        <input
          type="text"
          id="toLocation"
          placeholder="e.g. Lagos Lab, Lomé Store"
        />
      </div>

      <div>
        <label for="quantityMoved">Quantity Moved</label>
        <input
          type="number"
          step="0.01"
          id="quantityMoved"
          placeholder="e.g. 2"
        />
      </div>

      <div>
        <label for="quantityReturned">Quantity Returned</label>
        <input
          type="number"
          step="0.01"
          id="quantityReturned"
          placeholder="e.g. 0.5"
        />
      </div>

      <div>
        <label for="remainingQuantity">Remaining Quantity</label>
        <input
          type="number"
          step="0.01"
          id="remainingQuantity"
          placeholder="e.g. 1.5"
          value="<%= sample.currentQuantity ?? '' %>"
        />
      </div>

      <div>
        <label for="unit">Unit</label>
        <select id="unit">
          <option value="L" <%= sample.quantityUnit === 'L' ? 'selected' : '' %>>L</option>
          <option value="mL" <%= sample.quantityUnit === 'mL' ? 'selected' : '' %>>mL</option>
        </select>
      </div>

      <div style="grid-column: 1 / -1;">
        <label for="movementNote">Note</label>
        <textarea
          id="movementNote"
          rows="3"
          placeholder="Explain movement details"
        ></textarea>
      </div>
    </div>

    <button type="button" id="logMovementBtn">Log Movement</button>
    <div id="movementMessage" class="message"></div>

    <div class="section-title">Movement History</div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Movement Type</th>
            <th>From</th>
            <th>To</th>
            <th>Qty Moved</th>
            <th>Qty Returned</th>
            <th>Remaining</th>
            <th>Unit</th>
            <th>Note</th>
            <th>Moved At</th>
          </tr>
        </thead>
        <tbody>
          <% if (!movements || movements.length === 0) { %>
            <tr>
              <td colspan="10" style="text-align:center;">No movement history yet.</td>
            </tr>
          <% } else { %>
            <% movements.forEach((item, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= item.movementType %></td>
                <td><%= item.fromLocation || '-' %></td>
                <td><%= item.toLocation || '-' %></td>
                <td><%= item.quantityMoved ?? '-' %></td>
                <td><%= item.quantityReturned ?? '-' %></td>
                <td><%= item.remainingQuantity ?? '-' %></td>
                <td><%= item.unit || '-' %></td>
                <td><%= item.note || '-' %></td>
                <td><%= item.movedAt %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    const logMovementBtn = document.getElementById('logMovementBtn');
    const movementMessage = document.getElementById('movementMessage');

    logMovementBtn.addEventListener('click', async () => {
      try {
        const response = await fetch('/api/samples/<%= sample.id %>/movements', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            movementType: document.getElementById('movementType').value,
            fromLocation: document.getElementById('fromLocation').value.trim(),
            toLocation: document.getElementById('toLocation').value.trim(),
            quantityMoved: document.getElementById('quantityMoved').value,
            quantityReturned: document.getElementById('quantityReturned').value,
            remainingQuantity: document.getElementById('remainingQuantity').value,
            unit: document.getElementById('unit').value,
            note: document.getElementById('movementNote').value.trim()
          })
        });

        const data = await response.json();
        movementMessage.style.display = 'block';

        if (response.ok) {
          movementMessage.className = 'message success';
          movementMessage.textContent = data.message;
          setTimeout(() => {
            window.location.reload();
          }, 700);
        } else {
          movementMessage.className = 'message error';
          movementMessage.textContent = data.message || 'Failed to log movement.';
        }
      } catch (error) {
        movementMessage.style.display = 'block';
        movementMessage.className = 'message error';
        movementMessage.textContent = 'Server error. Failed to log movement.';
      }
    });
  </script>
</body>
</html>